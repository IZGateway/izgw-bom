<?xml version="1.0" encoding="UTF-8"?>
<!--
  versions-rules.xml
  Configuration for versions-maven-plugin (display-plugin-updates, display-property-updates).

  Rules here constrain which versions the plugin will suggest, supplementing the
  allowMajorUpdates=false / allowMinorUpdates=true global defaults set in pom.xml.

  See: https://www.mojohaus.org/versions/versions-maven-plugin/version-rules.html
-->
<ruleset comparisonMethod="maven"
         xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0
                             https://www.mojohaus.org/versions-maven-plugin/xsd/rule-2.0.0.xsd">

    <rules>
        <!--
          Global: ignore pre-release versions (alpha, beta, rc, milestone).
          Only stable releases should be suggested as updates.
        -->
        <rule>
            <ignoreVersions>
                <ignoreVersion type="regex">.*[-\.]alpha.*</ignoreVersion>
                <ignoreVersion type="regex">.*[-\.]beta.*</ignoreVersion>
                <ignoreVersion type="regex">.*[-\.]rc.*</ignoreVersion>
                <ignoreVersion type="regex">.*[-\.]m\d+.*</ignoreVersion>
                <ignoreVersion type="regex">.*[-\.]milestone.*</ignoreVersion>
                <ignoreVersion type="regex">.*\.Alpha.*</ignoreVersion>
                <ignoreVersion type="regex">.*\.Beta.*</ignoreVersion>
                <ignoreVersion type="regex">.*\.RC.*</ignoreVersion>
                <ignoreVersion type="regex">.*\.M\d+.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <!--
          Apache Maven itself: stay within the 3.9.x line.
          The CI/CD pipeline is pinned to 3.9.14; do not suggest 4.x.
        -->
        <rule groupId="org.apache.maven" artifactId="apache-maven">
            <ignoreVersions>
                <ignoreVersion type="regex">^[^3]\..*</ignoreVersion>
                <ignoreVersion type="regex">^3\.[^9]\..*</ignoreVersion>
            </ignoreVersions>
        </rule>

        <!--
          Bouncy Castle FIPS: never suggest any updates. Managed manually
          for FIPS 140-2 certification compatibility.
          Also listed in automation-exclusions.txt for the workflow excludes argument.
        -->
        <rule groupId="org.bouncycastle" artifactId="bc-fips">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.bouncycastle" artifactId="bcpkix-fips">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.bouncycastle" artifactId="bctls-fips">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>

    </rules>

</ruleset>
