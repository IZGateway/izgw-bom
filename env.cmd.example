@echo off
REM ============================================================
REM .env.cmd — local environment variables for simulate-publish.cmd
REM
REM This file is NOT checked into source control (.gitignore).
REM Copy/rename from env.cmd.example, then fill in your values below.
REM ============================================================

REM --- Required: NVD API key for OWASP Dependency-Check ---
REM Get one free at: https://nvd.nist.gov/developers/request-an-api-key
set NVD_API_KEY=

REM --- Optional: Sonatype OSS Index credentials ---
REM Log in at https://ossindex.sonatype.org to get your token.
REM Your username is your email; your password is the generated PAT.
set OSS_INDEX_USERNAME=
set OSS_INDEX_PASSWORD=

REM --- Optional: Set to 1 to skip the dependency-check scan ---
set SKIP_DC=0
